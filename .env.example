# Copy this file to .env and fill in your real values.
# .env is git-ignored; .env.example is safe to commit.
SQL_CONNECTION_STRING="DRIVER={ODBC Driver 18 for SQL Server};SERVER=<your-server>.database.windows.net;DATABASE=<your-db>;UID=<user>;PWD=<password>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;"
