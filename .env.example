# Copy this file to .env and fill in your real values.
# .env is git-ignored; .env.example is safe to commit.
SQL_CONNECTION_STRING="DRIVER={ODBC Driver 18 for SQL Server};SERVER=<your-server>.database.windows.net;DATABASE=<your-db>;UID=<user>;PWD=<password>;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;"

# LLM backend (routed through LiteLLM — https://docs.litellm.ai/docs/providers)
# Pick ONE model string + the matching API key below; switch providers by
# changing these two lines only, no code change needed.
LLM_MODEL="gemini/gemini-1.5-flash"

# Set whichever key(s) match LLM_MODEL's provider — only one is required.
GEMINI_API_KEY="your-gemini-api-key"
# OPENAI_API_KEY="your-openai-key"
# ANTHROPIC_API_KEY="your-anthropic-key"
